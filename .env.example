# LUXE LINE — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# --- Site ---
# NEXT_PUBLIC_SITE_URL=https://luxe-line.vercel.app

# --- Analytics (optional) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=luxe-line.vercel.app

# --- Newsletter (optional — wire up when backend lands) ---
# RESEND_API_KEY=
# NEWSLETTER_AUDIENCE_ID=
